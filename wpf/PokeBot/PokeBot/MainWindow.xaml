				<Label x:Name="HP0" Content="0" Style="{StaticResource ValueLabel}" FontSize="22" Canvas.Left="279" Canvas.Top="26"/>
				<Label x:Name="ATTK0" Content="0" Style="{StaticResource ValueLabel}" FontSize="22" Canvas.Left="319" Canvas.Top="26"/>
				<Label x:Name="DEF0" Content="0" Style="{StaticResource ValueLabel}" FontSize="22" Canvas.Left="359" Canvas.Top="26"/>
