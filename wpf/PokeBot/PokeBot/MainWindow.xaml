					<!-- 1 -->
					<Label x:Name="NombreProb"
						   Content="Regice"
						   Style="{StaticResource ValueLabel}"
						   FontSize="18"
						   Width="122"
						   HorizontalContentAlignment="Center"
						   Canvas.Left="54"
						   Canvas.Top="12"/>

					<!-- 2 -->
					<Label x:Name="Probabilidad"
