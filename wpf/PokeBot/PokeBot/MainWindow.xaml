                   Canvas.Left="410"
                   Canvas.Top="5"/>

			<Label Content="encontrados"
                   Style="{StaticResource HeaderLabel}"
                   Width="92"
                   Canvas.Left="405"
                   Canvas.Top="20"/>

			<!-- IMPORTANT: Probs ha de ser Grid perquè el teu codi compili -->
