                           Width="68"
						   HorizontalContentAlignment="Center"
                           Canvas.Left="222"
                           Canvas.Top="28"/>

					<!-- 8 -->
					<Label x:Name="PhaseEncounters"
                           Content="0"
                           Style="{StaticResource ValueLabel}"
                           FontSize="17"
                           Width="48"
						   HorizontalContentAlignment="Center"
                           Canvas.Left="294"
                           Canvas.Top="14"/>

					<!-- 9 -->
					<Label x:Name="PhaseEncountersPercent"
                           Content="0%"
                           Style="{StaticResource SmallValueLabel}"
                           Width="48"
						   HorizontalContentAlignment="Center"
                           Canvas.Left="294"
                           Canvas.Top="29"/>

					<!-- 10 -->
					<Label x:Name="TotalEncounters"
                           Content="0"
                           Style="{StaticResource ValueLabel}"
                           FontSize="17"
                           Width="58"
						   HorizontalContentAlignment="Center"
                           Canvas.Left="348"
                           Canvas.Top="14"/>

					<!-- 11 -->
					<Label x:Name="TotalShinyRatio"
                           Content="✨ 0/0"
                           Style="{StaticResource SmallValueLabel}"
                           Width="70"
						   HorizontalContentAlignment="Center"
                           Canvas.Left="340"
                           Canvas.Top="29"/>

					<!-- 12 -->
					<Label x:Name="ShiniesObtained"
                           Content="0/0"
                           Style="{StaticResource ValueLabel}"
                           FontSize="17"
                           Width="62"
						   HorizontalContentAlignment="Center"
                           Canvas.Left="420"
                           Canvas.Top="14"/>

					<!-- 13 -->
					<Label x:Name="ShiniesMissed"
                           Content="(0 huídos)"
                           Style="{StaticResource SmallValueLabel}"
                           Width="78"
						   HorizontalContentAlignment="Center"
                           Canvas.Left="412"
                           Canvas.Top="29"/>
				</Canvas>
			</Grid>
		</Canvas>

		<!-- Taula inferior esquerra -->
		<Canvas x:Name="TablaEncuentrosPanel"
                Width="640"
                Height="300"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="20,0,0,20"
                Background="Transparent"
