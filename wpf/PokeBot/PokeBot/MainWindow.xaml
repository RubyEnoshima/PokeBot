                   Style="{StaticResource HeaderLabel}"
                   Width="110"
                   Canvas.Left="298"
                   Canvas.Top="0"/>

			<!-- Subcapçaleres -->
			<Label Content="SV"
                   Style="{StaticResource HeaderLabel}"
                   Width="56"
                   Canvas.Left="168"
                   Canvas.Top="24"/>

			<Label Content="IV SUM"
                   Style="{StaticResource HeaderLabel}"
                   Width="68"
                   Canvas.Left="222"
                   Canvas.Top="24"/>

			<Label x:Name="Fase_label"
