				<Label x:Name="SPEED0" Content="0" Style="{StaticResource ValueLabel}" FontSize="22" Canvas.Left="479" Canvas.Top="26"/>
				<Label x:Name="TOTAL0" Content="0" Style="{StaticResource ValueLabel}" FontSize="22" Canvas.Left="515" Canvas.Top="26"/>
				<Label x:Name="SV0" Content="0" Style="{StaticResource ValueLabel}" FontSize="22" Width="69" Canvas.Left="555" Canvas.Top="26"/>
			</Canvas>

			<Canvas Margin="0,63,0,0" Width="624" Height="81">
