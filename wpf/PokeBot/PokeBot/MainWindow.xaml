				<Label x:Name="Nivel2" Content="0" Style="{StaticResource ValueLabel}" FontSize="22" Canvas.Left="223" Canvas.Top="26"/>
				<Label x:Name="HP2" Content="0" Style="{StaticResource ValueLabel}" FontSize="22" Canvas.Left="279" Canvas.Top="26"/>
