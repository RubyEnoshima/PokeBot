                Width="0"
                Height="500"
                VerticalAlignment="Bottom"
                Margin="20,0,0,20"
                Background="Transparent"
                Panel.ZIndex="100">

			<Label x:Name="EncuentrosLabel"
                   Content="Encuentros:"
                   Style="{StaticResource ValueLabel}"
                   FontSize="22"
                   Width="110"
