<Window x:Class="PokeBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PokeBot"
        Height="800"
        Width="1593"
        Closing="Cerrar"
        Background="#1F2020"
        MinWidth="1600"
        MinHeight="800"
        MaxWidth="1600"
        MaxHeight="800">

	<Window.Resources>

		<Style x:Key="OutlineLabel" TargetType="Label">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Padding" Value="2"/>
			<Setter Property="Background" Value="{x:Null}"/>
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect ShadowDepth="0" Color="Black" BlurRadius="2"/>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="HeaderLabel" TargetType="Label" BasedOn="{StaticResource OutlineLabel}">
			<Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Pokémon DS Font"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<Style x:Key="ValueLabel" TargetType="Label" BasedOn="{StaticResource OutlineLabel}">
			<Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Pokémon DS Font"/>
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<Style x:Key="SmallValueLabel" TargetType="Label" BasedOn="{StaticResource OutlineLabel}">
			<Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Pokémon DS Font"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Foreground" Value="#D0D0D0"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

	</Window.Resources>

	<Grid Name="Lista">

		<!-- Menú superior -->
		<Menu VerticalAlignment="Top" Panel.ZIndex="500">
			<MenuItem Header="Archivo">
				<MenuItem Header="Reset" Click="Reset"/>
				<MenuItem Header="Guardar" Click="Guardar"/>
				<Separator />
				<MenuItem Header="Salir sin guardar" Click="SalirSinGuardar"/>
				<MenuItem Header="Salir" Click="Salir"/>
			</MenuItem>
			<MenuItem Header="Opciones">
				<MenuItem Header="Guardar al salir" x:Name="Guardar_salir" IsCheckable="True" IsChecked="True" Checked="GuardarSalirC" Unchecked="GuardarSalirU" />
				<MenuItem Header="Reset después de shiny" x:Name="Reset_shiny" IsCheckable="True" IsChecked="True" Checked="ResetShinyC" Unchecked="ResetShinyU" />
			</MenuItem>
		</Menu>

		<!-- Controls -->
		<Canvas x:Name="ControlsPanel"
                Width="800"
                Height="62"
                HorizontalAlignment="right"
                VerticalAlignment="Top"
                Margin="0,34,18,0"
                Panel.ZIndex="250">

			<Button Width="22"
                    Height="22"
                    Click="Play"
                    Tag="play"
                    PreviewMouseDown="ImagenPeque"
                    PreviewMouseUp="ImagenGrande"
                    Canvas.Left="275"
                    Canvas.Top="0">
				<Image x:Name="playImagen" Source="Imgs/play_big.png" Height="19" Width="17"/>
			</Button>

			<Button Width="22"
                    Height="22"
                    Click="Stop"
                    Tag="stop"
                    PreviewMouseDown="ImagenPeque"
                    PreviewMouseUp="ImagenGrande"
                    Canvas.Left="307"
                    Canvas.Top="0">
				<Image x:Name="stopImagen" Source="Imgs/stop_big.png" Height="18" Width="17"/>
			</Button>

			<ComboBox FontFamily="pack://application:,,,/Fonts/#Pokémon DS Font"
                      FontSize="18"
                      SelectionChanged="CambiarModo"
                      Width="230"
                      Height="21"
                      Canvas.Left="355"
                      Canvas.Top="0">
				<ComboBoxItem IsSelected="True"
                              FontFamily="pack://application:,,,/Fonts/#Pokémon DS Font"
                              Content="Pokémon salvaje"/>
				<ComboBoxItem FontFamily="pack://application:,,,/Fonts/#Pokémon DS Font"
                              Content="Encuentro estático"/>
			</ComboBox>
		</Canvas>

		<!-- Taula superior dreta -->
		<Canvas x:Name="Probs_MAIN"
                Width="520"
                Height="620"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,72,0,0"
                Panel.ZIndex="200">

			<!-- Indicador horari -->
			<Image x:Name="TimeIcon"
                   Width="18"
                   Height="18"
                   Canvas.Left="0"
                   Canvas.Top="14"
                   Source="Imgs/play.png"/>

			<Label x:Name="TimeLabel"
                   Content="Tarde"
                   Style="{StaticResource HeaderLabel}"
                   Width="70"
                   Canvas.Left="100"
                   Canvas.Top="8"/>

			<!-- Ruta  -->
			<ComboBox x:Name="ComboRutas"
                      FontFamily="pack://application:,,,/Fonts/#Pokémon DS Font"
                      FontSize="18"
                      SelectionChanged="CambiarRuta"
                      Width="160"
                      Height="21"
                      Canvas.Left="0"
                      Canvas.Top="12"/>

			<ToggleButton x:Name="RadioToggle"
                          Content="Radio"
                          FontFamily="pack://application:,,,/Fonts/#Pokémon DS Font"
                          FontSize="14"
                          Width="62"
                          Height="22"
                          Click="RadioToggle_Click"
                          Canvas.Left="166"
                          Canvas.Top="597"/>

			<Label x:Name="RadioStatus"
                   Content="OFF"
                   Style="{StaticResource SmallValueLabel}"
                   Width="40"
                   Canvas.Left="226"
                   Canvas.Top="600"/>

			<Label x:Name="Horario"
				   Content="Horario"
				   Style="{StaticResource SmallValueLabel}"
				   FontSize="18"
				   Width="40"
				   Canvas.Left="-250"
				   Canvas.Top="575"/>

			<!-- Dropdown horari -->
			<ComboBox x:Name="CbHorario"
					  FontFamily="pack://application:,,,/Fonts/#Pokémon DS Font"
					  FontSize="18"
					  Width="120"
					  Height="21"
					  SelectionChanged="CbHorario_SelectionChanged"
					  Canvas.Left="-250"
					  Canvas.Top="598">

				<ComboBoxItem Content="Auto" Tag="auto" IsSelected="True"/>
				<ComboBoxItem Content="Mañana" Tag="Mañana"/>
				<ComboBoxItem Content="Tarde" Tag="Tarde"/>
				<ComboBoxItem Content="Noche" Tag="Noche"/>

			</ComboBox>

			<Label x:Name="Dia"
				   Style="{StaticResource SmallValueLabel}"
				   FontSize="18"
				   Content="Día"
				   Width="40"
				   Canvas.Left="-100"
				   Canvas.Top="575"/>

			<!-- Dropdown dia -->
			<ComboBox x:Name="CbDia"
					  FontFamily="pack://application:,,,/Fonts/#Pokémon DS Font"
					  FontSize="18"
					  Width="120"
					  Height="21"
					  SelectionChanged="CbDia_SelectionChanged"
					  Canvas.Left="-100"
					  Canvas.Top="598">

				<ComboBoxItem Content="Auto" Tag="auto" IsSelected="True"/>
				<ComboBoxItem Content="Miércoles" Tag="Wednesday"/>
				<ComboBoxItem Content="Jueves" Tag="Thursday"/>

			</ComboBox>

			<!-- Botó fase -->
			<Button Content="Reiniciar fase"
					FontFamily="pack://application:,,,/Fonts/#Pokémon DS Font"
					FontSize="14"
					Width="80"
					Height="22"
